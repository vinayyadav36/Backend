{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus",  "type": "datasource", "pluginId": "prometheus" },
    { "name": "DS_LOKI",       "label": "Loki",        "type": "datasource", "pluginId": "loki"       }
  ],
  "title": "Project Jarvis — Dark Ops Command Center",
  "uid":   "jarvis-dark-ops",
  "tags":  ["jarvis", "einstein", "dark-ops"],
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "🌍 Global Syndicate Map",
      "type": "geomap",
      "description": "Real-time Front Door traffic routing — East US vs West US",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": {
        "view": { "id": "zero", "lat": 30, "lon": -95, "zoom": 3 },
        "layers": [
          {
            "name": "Origin Traffic",
            "type": "markers",
            "config": { "style": { "color": { "fixed": "#F2495C" }, "size": { "fixed": 10 } } }
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (region) (rate(http_requests_total{job='api-gateway'}[1m]))",
          "legendFormat": "{{region}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "💓 Heartbeat Pulse (Primary Region)",
      "type": "timeseries",
      "description": "Sentinel health-check success rate. Drop → Coup imminent.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#73BF69" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": 0 },
              { "color": "#73BF69", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg_over_time(up{job='jarvis-primary'}[30s])",
          "legendFormat": "Primary Health"
        }
      ]
    },
    {
      "id": 3,
      "title": "🔥 Vault Shredder — Data Burn Rate",
      "type": "gauge",
      "description": "GB permanently eliminated by the Vault Shredder this month.",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0   },
              { "color": "yellow", "value": 10  },
              { "color": "red",    "value": 100 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "jarvis_vault_shredded_gb_total",
          "legendFormat": "Shredded (GB)"
        }
      ]
    },
    {
      "id": 4,
      "title": "🧠 Einstein Brain — Reasoning Latency",
      "type": "timeseries",
      "description": "p50 / p95 / p99 latency of /brain/reason calls.",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{handler='/brain/reason'}[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{handler='/brain/reason'}[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{handler='/brain/reason'}[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 5,
      "title": "🔌 Circuit Breaker Status",
      "type": "stat",
      "description": "Current state of each NestJS circuit breaker.",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "jarvis_circuit_breaker_state{name='brain-reason'}",        "legendFormat": "brain-reason" },
        { "expr": "jarvis_circuit_breaker_state{name='advisor-brief'}",       "legendFormat": "advisor-brief" },
        { "expr": "jarvis_circuit_breaker_state{name='brain-reason-async'}",  "legendFormat": "brain-reason-async" }
      ]
    },
    {
      "id": 6,
      "title": "🚫 Hit List — Blackholed IPs (Last 24 h)",
      "type": "table",
      "description": "Top 10 IPs currently blocked by Einstein in Azure Front Door WAF.",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 10 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "topk(10, count by (ip) ({job='consigliere'} |= 'WAF_IP_BLOCK' | json | __error__=''))",
          "legendFormat": "{{ip}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "⚡ Panic Button — Trigger Regional Coup",
      "type": "text",
      "description": "HMAC-signed manual failover. Use only when sentinel coup fails.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "options": {
        "mode": "html",
        "content": "<div style='text-align:center;padding:10px;'><p style='color:#F2495C;font-weight:bold;font-size:14px;'>⚠ EMERGENCY FAILOVER</p><button onclick=\"fetch('/api/v1/brain/ops/trigger-coup',{method:'POST',headers:{'Content-Type':'application/json','x-tenant-id':'system'},body:JSON.stringify({hmac_signature:'__SIGN_BEFORE_USE__',reason:'manual_dashboard_coup'})}).then(r=>r.json()).then(d=>alert(JSON.stringify(d))).catch(e=>alert(e))\" style='background:#C4162A;color:white;border:none;padding:12px 24px;font-size:16px;border-radius:4px;cursor:pointer;'>🔴 INITIATE COUP</button><p style='color:#888;font-size:11px;margin-top:8px;'>Requires valid HMAC signature. Replace __SIGN_BEFORE_USE__.</p></div>"
      }
    },
    {
      "id": 8,
      "title": "🛡️ Active System Suggestions",
      "type": "table",
      "description": "Einstein advisor recommendations pending admin action.",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jarvis_system_suggestions_total{status='Pending'}",
          "legendFormat": "{{category}}"
        }
      ]
    }
  ]
}

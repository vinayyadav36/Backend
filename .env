# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=development
PORT=5000

# Frontend URL (update when deployed)
FRONTEND_URL=http://localhost:3000

# ========================================
# DATABASE CONFIGURATION
# ========================================
# MongoDB Atlas Connection String
# Replace <username>, <password>, and luster> with your values
MONGODB_URI=mongodb+srv://hotel_admin:VINAY_2551@cluster0.rpghi21.mongodb.net/admin?appName=Cluster0

# For local MongoDB (alternative):
# MONGODB_URI=mongodb://localhost:27017/hotel-management

# ========================================
# JWT CONFIGURATION (Authentication)
# ========================================
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# Main JWT secret for access tokens (7 days expiry)
JWT_SECRET=b3ad4a3ee220af22deb4571d6271e139d46222b81fa6ba46b3ec0ca83615d5612c465692a29be070475d97f7801ad2e6abda93fa56e354ddf9a577ffd7fe438c
# JWT access token expiration
JWT_EXPIRE=7d

# Refresh token secret (different from JWT_SECRET)
JWT_REFRESH_SECRET=3d02ec7f1a6e16d26f138b15afff4e18c8620f75f7819a5f7028525c20f6cface6040ba842ddb530b96fd3006429d45394b2897462710c87cf30cce70019f659

# Refresh token expiration
JWT_REFRESH_EXPIRE=30d

# ========================================
# PASSWORD HASHING
# ========================================
# Bcrypt rounds (10-12 recommended, higher = more secure but slower)
BCRYPT_ROUNDS=12

# ========================================
# RATE LIMITING (Security)
# ========================================
# Max requests per 15 minutes per IP
RATE_LIMIT=100

# ========================================
# FILE UPLOAD CONFIGURATION
# ========================================
# Max file size in bytes (5MB = 5242880)
MAX_FILE_SIZE=5242880

# Upload directory path
UPLOAD_PATH=./uploads

# Allowed file MIME types (comma separated)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# ========================================
# EMAIL CONFIGURATION (For OTP & Notifications)
# ========================================
# Gmail Example (requires App Password, not regular password)
# 1. Enable 2-Factor Authentication in Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Email sender details
FROM_EMAIL=noreply@hotelmanagement.com
FROM_NAME=Hotel Management System

# ========================================
# DIGILOCKER INTEGRATION (Indian Government ID Verification)
# ========================================
# Register at: https://api.digitallocker.gov.in/
DIGILOCKER_CLIENT_ID=your_digilocker_client_id_here
DIGILOCKER_CLIENT_SECRET=your_digilocker_client_secret_here
DIGILOCKER_REDIRECT_URI=http://localhost:5000/api/v1/guests/digilocker/callback

# ========================================
# PAYMENT GATEWAY (Optional - Future Use)
# ========================================
# Razorpay (Indian Payment Gateway)
# Register at: https://razorpay.com/
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Stripe (International)
# Register at: https://stripe.com/
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ========================================
# SMS SERVICE (For OTP via SMS - Optional)
# ========================================
# Twilio (https://www.twilio.com/)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# MSG91 (Indian SMS Service - https://msg91.com/)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=your_sender_id

# ========================================
# CLOUD STORAGE (For Production File Uploads)
# ========================================
# AWS S3 (https://aws.amazon.com/s3/)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=hotel-management-uploads

# Cloudinary (https://cloudinary.com/) - Easier alternative
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ========================================
# LOGGING CONFIGURATION
# ========================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ========================================
# REDIS (Optional - For Session Management)
# ========================================
# Redis Cloud: https://redis.com/try-free/
REDIS_URL=redis://username:password@host:port

# ========================================
# ANALYTICS & MONITORING (Optional)
# ========================================
# Sentry (Error Tracking - https://sentry.io/)
SENTRY_DSN=your_sentry_dsn_here

# Google Analytics
GA_TRACKING_ID=UA-XXXXXXXXX-X

# ========================================
# CORS CONFIGURATION
# ========================================
# Allowed origins (comma separated for multiple)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourfrontend.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_WINDOW=15
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_REGISTER_WINDOW=60
RATE_LIMIT_REGISTER_MAX=3

# Trust Proxy (set to true if behind nginx/apache)
TRUST_PROXY=false

# Compression
COMPRESSION_LEVEL=6

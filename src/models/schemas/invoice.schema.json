{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Invoice",
  "type": "object",
  "required": ["customer", "items", "totalAmount"],
  "properties": {
    "invoiceNumber": { "type": "string" },
    "customer": {
      "type": "object",
      "properties": {
        "contact_id": { "type": "string" },
        "name": { "type": "string" },
        "gstin": { "type": "string", "pattern": "^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$" }
      }
    },
    "items": {
      "type": "array",
      "itemSchema": {
        "type": "object",
        "properties": {
          "sku": { "type": "string" },
          "description": { "type": "string" },
          "qty": { "type": "number", "minimum": 1 },
          "rate": { "type": "number", "minimum": 0 },
          "tax_rate": { "type": "number", "minimum": 0, "maximum": 100 },
          "hsn": { "type": "string" }
        }
      }
    },
    "totals": {
      "type": "object",
      "properties": {
        "sub_total": { "type": "number" },
        "tax_total": { "type": "number" },
        "rounding": { "type": "number" },
        "grand_total": { "type": "number" }
      }
    },
    "gst": {
      "type": "object",
      "properties": {
        "supply_type": { "type": "string", "enum": ["B2B", "B2C", "EXPORT"] },
        "reverse_charge": { "type": "boolean" }
      }
    },
    "status": { "type": "string", "enum": ["draft", "issued", "paid", "cancelled"] },
    "ledger_posted": { "type": "boolean" }
  }
}

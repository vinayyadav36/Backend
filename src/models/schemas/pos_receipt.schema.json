{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "POSReceipt",
  "type": "object",
  "required": ["items", "total", "billDate"],
  "properties": {
    "invoiceNumber": { "type": "string" },
    "customerId": { "type": "string" },
    "items": { "type": "array" },
    "subtotal": { "type": "number", "minimum": 0 },
    "gstAmount": { "type": "number", "minimum": 0 },
    "cgstAmount": { "type": "number", "minimum": 0 },
    "sgstAmount": { "type": "number", "minimum": 0 },
    "igstAmount": { "type": "number", "minimum": 0 },
    "total": { "type": "number", "minimum": 0 },
    "paymentMethod": { "type": "string" },
    "gstType": { "type": "string", "enum": ["intra-state", "inter-state"] },
    "placeOfSupply": { "type": "string" },
    "billDate": { "type": "date" },
    "status": { "type": "string", "enum": ["completed", "cancelled", "returned"] }
  }
}

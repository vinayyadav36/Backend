{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Room",
  "type": "object",
  "required": ["number", "type", "rate"],
  "properties": {
    "number": { "type": "string" },
    "type": { "type": "string", "enum": ["single", "double", "suite", "deluxe", "penthouse"] },
    "rate": { "type": "number", "minimum": 0 },
    "floor": { "type": "number" },
    "capacity": { "type": "number", "minimum": 1 },
    "status": { "type": "string", "enum": ["available", "occupied", "maintenance", "reserved"] },
    "amenities": { "type": "array", "itemSchema": { "type": "string" } },
    "description": { "type": "string" }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MasterAdmin",
  "type": "object",
  "required": ["type", "status"],
  "properties": {
    "type": { "type": "string", "enum": ["master_admin"] },
    "status": { "type": "string", "enum": ["active", "suspended", "deleted"] },
    "linked_apps": { "type": "array", "itemSchema": { "type": "string" } },
    "permissions": {
      "type": "object",
      "properties": {
        "scope": { "type": "string", "enum": ["global", "tenant"] },
        "mode": { "type": "string", "enum": ["policy_driven", "full_access"] },
        "allow_impersonation": { "type": "boolean" }
      }
    },
    "auth": {
      "type": "object",
      "properties": {
        "method": { "type": "string" },
        "mfa_enabled": { "type": "boolean" }
      }
    }
  }
}
